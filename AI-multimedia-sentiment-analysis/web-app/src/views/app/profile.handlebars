<section class="analysis-page">
  <div class="container-page">
    <div class="analysis-app-layout">
      {{> app-sidebar}}

      <main class="analysis-main-content">
        <section class="analysis-internal-section">
          <div class="analysis-section-title">
            <span class="page-badge">Perfil</span>

            <h1>
              Conta e
              <span class="text-gradient">preferências</span>.
            </h1>

            <p>
              Em breve esta área exibirá dados da conta, preferências de
              privacidade e configurações do usuário.
            </p>
          </div>

          <article class="analysis-profile-card surface-card">
            <div class="profile-avatar">
              👤
            </div>

            <div>
              <h2>Perfil do usuário</h2>

              <p>
                Dados da conta serão exibidos aqui depois que criarmos o serviço
                de perfil.
              </p>
            </div>
          </article>
        </section>
      </main>
    </div>
  </div>
</section>