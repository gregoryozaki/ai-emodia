<section class="analysis-page">
  <div class="container-page">
    <div class="analysis-app-layout">
      <main class="analysis-main-content">
        <section class="analysis-internal-section">
          <div class="detail-top-actions">
            <a href="/analises/nova" class="auth-back-link">
              ← Voltar para registrar
            </a>

            <a href="/historico" class="detail-history-link">
              Ver histórico
            </a>
          </div>

          <div class="analysis-section-title">
            <span class="page-badge">Detalhes</span>

            <h1>
              Análise
              <span class="text-gradient">emocional</span>.
            </h1>

            <p>
              Veja os dados registrados nessa análise.
            </p>
          </div>

          {{#if record.hasRiskAlert}}
            <div class="report-risk-box report-risk-critical">
              <span>Sinal de atenção</span>

              <h3>Atenção: termos sensíveis identificados</h3>

              <p>
                {{record.riskMessage}}
              </p>

              {{#if record.riskTerms}}
                <div class="report-risk-list">
                  <div class="report-risk-item">
                    <strong>Termos identificados</strong>
                    <small>{{record.riskTerms}}</small>
                  </div>
                </div>
              {{/if}}

              <div class="risk-alert-actions">
                <a href="tel:188" class="btn-emodia-primary">
                  Buscar ajuda agora — CVV 188
                </a>

                <a href="tel:192" class="btn-emodia-outline">
                  Emergência médica — SAMU 192
                </a>

                <a href="tel:190" class="btn-emodia-outline">
                  Risco ou violência — 190
                </a>

                <a href="/dashboard" class="btn-emodia-outline">
                  Voltar para dashboard
                </a>
              </div>

              <div class="risk-alert-support-text">
                <p>
                  Se houver risco imediato, ameaça, violência, abuso ou perigo
                  físico, procure uma pessoa de confiança ou acione um serviço
                  de emergência da sua região. O Emodia não realiza diagnóstico
                  e não substitui atendimento profissional.
                </p>
              </div>
            </div>
          {{/if}}

          {{#if record.hasVisualAnalysis}}
            <div class="report-risk-box">
              <span>Sinal visual complementar</span>

              <h3>Expressão facial estimada no vídeo</h3>

              <p>
                A análise visual identificou um sinal compatível com
                <strong>{{record.visualEmodiaEmotion}}</strong>
                com nível de confiança
                <strong>{{record.visualConfidenceLevel}}</strong>.
              </p>

              {{#if record.visualConfidencePercent}}
                <div class="report-risk-list">
                  <div class="report-risk-item">
                    <strong>Confiança média</strong>
                    <small>{{record.visualConfidencePercent}}</small>
                  </div>

                  {{#if record.visualEmotion}}
                    <div class="report-risk-item">
                      <strong>Classe original do modelo</strong>
                      <small>{{record.visualEmotion}}</small>
                    </div>
                  {{/if}}
                </div>
              {{/if}}

              <div class="risk-alert-support-text">
                <p>
                  Este resultado vem da análise automática de expressão facial
                  aparente. Ele não define a emoção principal, não realiza
                  diagnóstico e deve ser interpretado apenas como apoio à
                  análise textual ou transcrita.
                </p>
              </div>
            </div>
          {{/if}}

          <article class="detail-card surface-card">
            <div class="detail-header">
              <div>
                <span class="page-badge">
                  Resultado da análise
                </span>

                <h2>
                  Registro de
                  {{record.createdAt}}
                </h2>
              </div>

              <strong>
                Intensidade
                {{record.intensity}}/10
              </strong>
            </div>

            <div class="detail-grid">
              <div class="detail-item">
                <span>Modo de entrada</span>

                <strong>
                  {{#if record.inputMode}}
                    {{record.inputMode}}
                  {{else}}
                    TEXT
                  {{/if}}
                </strong>
              </div>

              <div class="detail-item">
                <span>Gatilhos detectados</span>

                <strong>
                  {{#if record.trigger}}
                    {{record.trigger}}
                  {{else}}
                    Não identificado
                  {{/if}}
                </strong>
              </div>

              <div class="detail-item">
                <span>Nível de atenção</span>

                <strong>
                  {{record.riskLevel}}
                </strong>
              </div>

              <div class="detail-item detail-emotion-highlight">
                <span>Emoção predominante</span>

                <strong>
                  {{record.emotionLabel}}
                </strong>

                <p>
                  Emoção principal identificada no conteúdo enviado.
                </p>
              </div>

              {{#if record.hasVisualAnalysis}}
                <div class="detail-item">
                  <span>Sinal visual complementar</span>

                  <strong>
                    {{record.visualEmodiaEmotion}}
                  </strong>
                </div>

                <div class="detail-item">
                  <span>Confiança visual</span>

                  <strong>
                    {{#if record.visualConfidencePercent}}
                      {{record.visualConfidencePercent}}
                    {{else}}
                      {{record.visualConfidenceLevel}}
                    {{/if}}
                  </strong>
                </div>
              {{/if}}

              {{#if record.riskTerms}}
                <div class="detail-item detail-item-full">
                  <span>Termos sensíveis</span>

                  <strong>
                    {{record.riskTerms}}
                  </strong>
                </div>
              {{/if}}

              {{#if record.transcript}}
                <div class="detail-item detail-item-full">
                  <span>Transcrição analisada</span>

                  <p>
                    {{record.transcript}}
                  </p>
                </div>
              {{else}}
                <div class="detail-item detail-item-full">
                  <span>Texto analisado</span>

                  <p>
                    {{record.content}}
                  </p>
                </div>
              {{/if}}
            </div>

            <div class="detail-bottom-actions">
              <a href="/dashboard" class="btn-emodia-primary">
                Ver no dashboard
              </a>

              <a href="/analises/nova" class="btn-emodia-outline">
                Registrar outra emoção
              </a>
            </div>
          </article>
        </section>
      </main>
    </div>

  </div>
</section>