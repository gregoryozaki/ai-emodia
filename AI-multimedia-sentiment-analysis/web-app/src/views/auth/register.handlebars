<section class="auth-page">
  <div class="container-page">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-8 col-xl-7">
        <article class="auth-card surface-card">
          <span class="page-badge">
            Cadastro de usuário
          </span>

          <h1>Criar conta no Emodia</h1>

          <p class="auth-subtitle">
            Preencha seus dados para começar a registrar e acompanhar suas
            emoções.
          </p>

          <form class="auth-form" action="#" method="post">
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <label for="fullName" class="form-label">Nome completo</label>
                <input
                  type="text"
                  class="form-control auth-input"
                  id="fullName"
                  name="fullName"
                  placeholder="Seu nome completo"
                />
              </div>

              <div class="col-12 col-md-6">
                <label for="birthDate" class="form-label">Data de nascimento</label>
                <input
                  type="date"
                  class="form-control auth-input"
                  id="birthDate"
                  name="birthDate"
                />
              </div>

              <div class="col-12">
                <label for="registerEmail" class="form-label">E-mail</label>
                <input
                  type="email"
                  class="form-control auth-input"
                  id="registerEmail"
                  name="email"
                  placeholder="seuemail@exemplo.com"
                />
              </div>

              <div class="col-12 col-md-6">
                <label for="registerPassword" class="form-label">Senha</label>
                <input
                  type="password"
                  class="form-control auth-input"
                  id="registerPassword"
                  name="password"
                  placeholder="Crie uma senha"
                />
              </div>

              <div class="col-12 col-md-6">
                <label for="confirmPassword" class="form-label">Confirmar senha</label>
                <input
                  type="password"
                  class="form-control auth-input"
                  id="confirmPassword"
                  name="confirmPassword"
                  placeholder="Repita a senha"
                />
              </div>

              <div class="col-12">
                <div class="form-check auth-check">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    value="true"
                    id="consentTerm"
                    name="consentTerm"
                  />

                  <label class="form-check-label" for="consentTerm">
                    Declaro que sou maior de 18 anos e aceito o termo de
                    consentimento e as diretrizes de privacidade do Emodia.
                  </label>
                </div>
              </div>
            </div>

            <button type="submit" class="btn-emodia-primary w-100 mt-4">
              Criar conta
            </button>
          </form>

          <p class="auth-bottom-text">
            Já possui conta?
            <a href="/login" class="auth-link">Entrar</a>
          </p>
        </article>
      </div>
    </div>
  </div>
</section>