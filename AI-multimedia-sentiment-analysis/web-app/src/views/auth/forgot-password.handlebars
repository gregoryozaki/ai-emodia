<section class="auth-page">
  <div class="container-page">
    <a href="/login" class="auth-back-link">
      ← Voltar para login
    </a>

    <div class="auth-shell auth-shell-simple auth-shell-recovery">
      <aside class="auth-aside">
        <div class="auth-logo-wrap auth-logo-aside">
          <img src="/img/logo-emodia.png" alt="Logo Emodia" class="auth-logo" />
        </div>

        <h1>
          Recupere sua senha com segurança.
        </h1>

        <p>
          Informe o e-mail cadastrado na sua conta. Se ele existir no Emodia,
          enviaremos um link temporário para redefinir sua senha.
        </p>

        <div class="auth-aside-list">
          <div>
            <strong>Link temporário</strong>
            <span>O acesso expira em poucos minutos para proteger sua conta.</span>
          </div>

          <div>
            <strong>Nova senha</strong>
            <span>Depois do link, você poderá cadastrar uma senha nova.</span>
          </div>
        </div>
      </aside>

      <article class="auth-card auth-form-card auth-recovery-card">
        <span class="page-badge">
          Recuperação de senha
        </span>

        <h2>
          Recupere o acesso.
        </h2>

        <p class="auth-subtitle">
          Digite o e-mail usado no cadastro.
        </p>

        {{#if success}}
          <div class="auth-alert auth-alert-success" data-flash-message>
            {{success}}
          </div>
        {{/if}}

        {{#if error}}
          <div class="auth-alert auth-alert-error" data-flash-message>
            {{error}}
          </div>
        {{/if}}

        <form action="/recuperar-senha" method="post" class="auth-form">
          <div class="auth-field">
            <label for="email" class="form-label">
              E-mail
            </label>

            <input
              type="email"
              id="email"
              name="email"
              class="form-control auth-input"
              placeholder="seuemail@exemplo.com"
              value="{{formData.email}}"
              required
            />
          </div>

          <button type="submit" class="btn-emodia-primary w-100">
            Enviar link de recuperação
          </button>
        </form>

        <p class="auth-recovery-footer">
          Lembrou a senha?
          <a href="/login">Entrar agora</a>
        </p>
      </article>
    </div>
  </div>
</section>