<section class="auth-page">
  <div class="container-page">
    <a href="/login" class="auth-back-link">
      ← Voltar
    </a>

    <div class="auth-shell auth-shell-simple">
      <aside class="auth-aside">
        <div class="auth-logo-wrap auth-logo-aside">
          <img src="/img/logo-emodia.png" alt="Logo Emodia" class="auth-logo" />
        </div>

        <span class="page-badge">Recuperação de acesso</span>

        <h1>Esqueceu sua senha?</h1>

        <p>
          Informe o e-mail cadastrado. Depois, o sistema enviará instruções para
          redefinir o acesso da sua conta.
        </p>

        <div class="auth-aside-list">
          <div>
            <strong>Segurança primeiro</strong>
            <span>Links de recuperação devem ter validade limitada.</span>
          </div>

          <div>
            <strong>Conta protegida</strong>
            <span>Nunca compartilhe seu link de redefinição de senha.</span>
          </div>
        </div>
      </aside>

      <article class="auth-card auth-form-card">
        <h2>Recuperar senha</h2>

        <p class="auth-subtitle">
          Digite seu e-mail para receber instruções de recuperação.
        </p>

        {{#if error}}
          <div class="auth-alert auth-alert-error">
            {{error}}
          </div>
        {{/if}}

        <form class="auth-form" action="/recuperar-senha" method="post">
          <div class="auth-field">
            <label for="email" class="form-label">E-mail</label>

            <input
              type="email"
              class="form-control auth-input"
              id="email"
              name="email"
              placeholder="seu@email.com"
              required
            />
          </div>

          <button type="submit" class="btn-emodia-primary w-100">
            Enviar link de recuperação
          </button>
        </form>

        <p class="auth-bottom-text">
          Lembrou sua senha?
          <a href="/login" class="auth-link">Fazer login</a>
        </p>
      </article>
    </div>
  </div>
</section>