<section class="auth-page">
  <div class="container-page">
    <a href="/login" class="auth-back-link">
      ← Voltar
    </a>

    <div class="auth-shell auth-shell-simple">
      <aside class="auth-aside">
        <div class="auth-logo-wrap auth-logo-aside">
          <img src="/img/logo-emodia.png" alt="Logo Emodia" class="auth-logo" />
        </div>

        <span class="page-badge">Nova senha</span>

        <h1>Redefina seu acesso</h1>

        <p>
          Crie uma nova senha segura para proteger seus registros emocionais.
        </p>

        <div class="auth-aside-list">
          <div>
            <strong>Use uma senha forte</strong>
            <span>Misture letras, números e caracteres especiais.</span>
          </div>

          <div>
            <strong>Evite reutilizar senhas</strong>
            <span>Não use a mesma senha de outros serviços.</span>
          </div>
        </div>
      </aside>

      <article class="auth-card auth-form-card">
        <h2>Redefinir senha</h2>

        <p class="auth-subtitle">
          Informe e confirme sua nova senha.
        </p>

        <form class="auth-form" action="/redefinir-senha" method="post">
          <div class="auth-field">
            <label for="newPassword" class="form-label">Nova senha</label>

            <div class="password-field">
              <input
                type="password"
                class="form-control auth-input"
                id="newPassword"
                name="password"
                placeholder="Digite a nova senha"
                required
              />

              <button
                type="button"
                class="password-toggle"
                data-toggle-password="newPassword"
                aria-label="Mostrar ou esconder senha"
              >
                👁
              </button>
            </div>
          </div>

          <div class="auth-field">
            <label for="newConfirmPassword" class="form-label">Confirmar senha</label>

            <div class="password-field">
              <input
                type="password"
                class="form-control auth-input"
                id="newConfirmPassword"
                name="confirmPassword"
                placeholder="Repita a nova senha"
                required
              />

              <button
                type="button"
                class="password-toggle"
                data-toggle-password="newConfirmPassword"
                aria-label="Mostrar ou esconder senha"
              >
                👁
              </button>
            </div>
          </div>

          <button type="submit" class="btn-emodia-primary w-100">
            Atualizar senha
          </button>
        </form>

        <p class="auth-bottom-text">
          Lembrou a senha?
          <a href="/login" class="auth-link">Fazer login</a>
        </p>
      </article>
    </div>
  </div>
</section>