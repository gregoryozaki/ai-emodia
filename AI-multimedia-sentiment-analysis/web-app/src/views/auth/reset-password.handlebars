<section class="auth-page">
  <div class="container-page">
    <a href="/login" class="auth-back-link">
      ← Voltar para login
    </a>

    <div class="auth-shell auth-shell-simple auth-shell-recovery">
      <aside class="auth-aside">
        <div class="auth-logo-wrap auth-logo-aside">
          <img src="/img/logo-emodia.png" alt="Logo Emodia" class="auth-logo" />
        </div>

        <h1>Defina uma nova senha.</h1>

        <p>
          Crie uma senha forte para proteger seus registros emocionais e manter
          sua conta segura.
        </p>

        <div class="auth-aside-list">
          <div>
            <strong>Senha forte</strong>
            <span>
              Use letras maiúsculas, minúsculas, número e símbolo.
            </span>
          </div>

          <div>
            <strong>Acesso renovado</strong>
            <span>
              Depois da alteração, entre usando a nova senha.
            </span>
          </div>
        </div>
      </aside>

      <article class="auth-card auth-form-card auth-recovery-card">
        <span class="page-badge">Nova senha</span>

        <h2>Redefinir senha.</h2>

        <p class="auth-subtitle">
          Informe e confirme sua nova senha.
        </p>

        {{#if error}}
          <div
            class="auth-alert auth-alert-error"
            role="alert"
            data-flash-message
          >
            {{error}}
          </div>
        {{/if}}

        <form
          action="/redefinir-senha/{{token}}"
          method="post"
          class="auth-form"
        >
          <div class="auth-field">
            <label for="newPassword" class="form-label">
              Nova senha
            </label>

            <div class="password-field">
              <input
                type="password"
                id="newPassword"
                name="newPassword"
                class="form-control auth-input"
                minlength="8"
                maxlength="72"
                autocomplete="new-password"
                aria-describedby="newPasswordHelp"
                required
              />

              <button
                type="button"
                class="password-toggle"
                data-toggle-password="newPassword"
                aria-label="Mostrar ou esconder senha"
              >
                👁
              </button>
            </div>

            <small class="auth-help-text" id="newPasswordHelp">
              Use entre 8 e 72 caracteres, com letra maiúscula, minúscula,
              número e caractere especial.
            </small>
          </div>

          <div class="auth-field">
            <label for="confirmNewPassword" class="form-label">
              Confirmar nova senha
            </label>

            <div class="password-field">
              <input
                type="password"
                id="confirmNewPassword"
                name="confirmNewPassword"
                class="form-control auth-input"
                minlength="8"
                maxlength="72"
                autocomplete="new-password"
                required
              />

              <button
                type="button"
                class="password-toggle"
                data-toggle-password="confirmNewPassword"
                aria-label="Mostrar ou esconder senha"
              >
                👁
              </button>
            </div>
          </div>

          <button type="submit" class="btn-emodia-primary w-100">
            Redefinir senha
          </button>
        </form>

        <p class="auth-recovery-footer">
          <a href="/login">Voltar para login</a>
        </p>
      </article>
    </div>
  </div>
</section>