<section class="auth-page">
  <div class="container-page">
    <a href="/login" class="auth-back-link">
      ← Voltar
    </a>

    <div class="row justify-content-center">
      <div class="col-12 col-md-10 col-lg-6 col-xl-5">
        <article class="auth-card surface-card text-center">
          <div class="auth-icon">
            🔐
          </div>

          <span class="page-badge">
            Nova senha
          </span>

          <h1>Redefinir senha</h1>

          <p class="auth-subtitle">
            Crie uma nova senha segura para sua conta.
          </p>

          <form
            class="auth-form text-start"
            action="/redefinir-senha"
            method="post"
          >
            <div class="mb-3">
              <label for="newPassword" class="form-label">Nova senha</label>

              <div class="password-field">
                <input
                  type="password"
                  class="form-control auth-input"
                  id="newPassword"
                  name="password"
                  placeholder="Digite a nova senha"
                  required
                />

                <button
                  type="button"
                  class="password-toggle"
                  data-toggle-password="newPassword"
                  aria-label="Mostrar ou esconder senha"
                >
                  👁
                </button>
              </div>
            </div>

            <div class="mb-4">
              <label for="newConfirmPassword" class="form-label">Confirmar senha</label>

              <div class="password-field">
                <input
                  type="password"
                  class="form-control auth-input"
                  id="newConfirmPassword"
                  name="confirmPassword"
                  placeholder="Repita a nova senha"
                  required
                />

                <button
                  type="button"
                  class="password-toggle"
                  data-toggle-password="newConfirmPassword"
                  aria-label="Mostrar ou esconder senha"
                >
                  👁
                </button>
              </div>
            </div>

            <button type="submit" class="btn-emodia-primary w-100">
              Atualizar senha
            </button>
          </form>

          <p class="auth-bottom-text">
            Lembrou a senha?
            <a href="/login" class="auth-link">Fazer login</a>
          </p>
        </article>
      </div>
    </div>
  </div>
</section>