<section class="analysis-page">
  <div class="container-page">
    <section class="analysis-dashboard-hero">
      <div class="row g-4 align-items-stretch">
        <div class="col-12 col-lg-7">
          <article class="analysis-welcome-card surface-card">
            <span class="page-badge">
              Área emocional
            </span>

            <h1>
              Bem-vindo à sua área de
              <span class="text-gradient">acompanhamento emocional</span>.
            </h1>

            <p>
              Registre suas emoções, acompanhe padrões ao longo do tempo e
              visualize relatórios que ajudam no seu autoconhecimento emocional.
            </p>
          </article>
        </div>

        <div class="col-12 col-lg-5">
          <article class="analysis-summary-card surface-card">
            <div class="summary-icon">
              🧠
            </div>

            <h2>Status da área</h2>

            <p>
              O registro textual já está ativo. Os próximos recursos irão
              incluir áudio, imagem, vídeo, gráficos e análise por IA.
            </p>

            <div class="summary-status">
              <span class="status-dot"></span>
              Sessão autenticada
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="new-record" class="analysis-section">
      <div class="row g-4 align-items-stretch">
        <div class="col-12 col-lg-5">
          <article class="analysis-form-card surface-card">
            <div class="section-header text-start">
              <h2>Registrar emoção por texto</h2>

              <p>
                Descreva como você está se sentindo agora. Esse registro ficará
                salvo no seu histórico emocional.
              </p>
            </div>

            {{#if success}}
              <div class="auth-alert auth-alert-success">
                Emoção registrada com sucesso.
              </div>
            {{/if}}

            {{#if error}}
              <div class="auth-alert auth-alert-error">
                {{error}}
              </div>
            {{/if}}

            <form
              action="/analises/registros"
              method="post"
              class="emotion-form"
            >
              <div class="auth-field">
                <label for="emotion" class="form-label">
                  Emoção principal
                </label>

                <select
                  id="emotion"
                  name="emotion"
                  class="form-select auth-input"
                  required
                >
                  <option value="">Selecione</option>
                  <option value="ALEGRIA">Alegria</option>
                  <option value="TRISTEZA">Tristeza</option>
                  <option value="RAIVA">Raiva</option>
                  <option value="MEDO">Medo</option>
                  <option value="NOJO">Nojo</option>
                  <option value="ANSIEDADE">Ansiedade</option>
                </select>
              </div>

              <div class="auth-field">
                <label for="intensity" class="form-label">
                  Intensidade
                </label>

                <select
                  id="intensity"
                  name="intensity"
                  class="form-select auth-input"
                  required
                >
                  <option value="">Selecione</option>
                  <option value="1">1 - Muito baixa</option>
                  <option value="2">2 - Baixa</option>
                  <option value="3">3 - Moderada</option>
                  <option value="4">4 - Alta</option>
                  <option value="5">5 - Muito alta</option>
                </select>
              </div>

              <div class="auth-field">
                <label for="trigger" class="form-label">
                  Possível gatilho
                </label>

                <input
                  type="text"
                  id="trigger"
                  name="trigger"
                  class="form-control auth-input"
                  placeholder="Ex.: trabalho, estudo, família, sono..."
                  value="{{formData.trigger}}"
                />
              </div>

              <div class="auth-field">
                <label for="content" class="form-label">
                  Relato
                </label>

                <textarea
                  id="content"
                  name="content"
                  class="form-control auth-input emotion-textarea"
                  placeholder="Escreva brevemente o que você está sentindo..."
                  maxlength="2000"
                  required
                >{{formData.content}}</textarea>
              </div>

              <button type="submit" class="btn-emodia-primary w-100">
                Salvar registro
              </button>
            </form>
          </article>
        </div>

        <div class="col-12 col-lg-7">
          <article id="history" class="analysis-panel surface-card">
            <div class="analysis-panel-header">
              <div>
                <h2>Histórico recente</h2>

                <p>
                  Seus últimos registros emocionais aparecem aqui.
                </p>
              </div>
            </div>

            {{#if records}}
              <div class="emotion-history-list">
                {{#each records}}
                  <article class="emotion-history-item">
                    <div class="emotion-history-top">
                      <div>
                        <strong>{{emotion}}</strong>
                        <span>{{inputMode}} · {{createdAt}}</span>
                      </div>

                      <span class="emotion-intensity">
                        Intensidade
                        {{intensity}}/5
                      </span>
                    </div>

                    {{#if trigger}}
                      <p class="emotion-trigger">
                        Gatilho:
                        {{trigger}}
                      </p>
                    {{/if}}

                    <p class="emotion-content">
                      {{content}}
                    </p>
                  </article>
                {{/each}}
              </div>
            {{else}}
              <div class="empty-state">
                <div class="empty-state-icon">📭</div>

                <h3>Nenhum registro encontrado</h3>

                <p>
                  Quando você registrar suas emoções, elas serão exibidas nesta
                  área.
                </p>
              </div>
            {{/if}}
          </article>
        </div>
      </div>
    </section>

    <section class="analysis-section">
      <div class="row g-4">
        <div class="col-12 col-md-6 col-xl-3">
          <article class="analysis-action-card surface-card">
            <div class="analysis-action-icon">T</div>
            <h3>Texto</h3>
            <p>Registro textual já disponível.</p>
            <a href="#new-record" class="btn-emodia-outline w-100">
              Registrar
            </a>
          </article>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <article class="analysis-action-card surface-card">
            <div class="analysis-action-icon">A</div>
            <h3>Áudio</h3>
            <p>Registre sua voz para futura análise emocional por fala.</p>
            <button type="button" class="btn-emodia-outline w-100" disabled>
              Em breve
            </button>
          </article>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <article class="analysis-action-card surface-card">
            <div class="analysis-action-icon">I</div>
            <h3>Imagem</h3>
            <p>Envie uma imagem para apoiar a identificação emocional.</p>
            <button type="button" class="btn-emodia-outline w-100" disabled>
              Em breve
            </button>
          </article>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
          <article class="analysis-action-card surface-card">
            <div class="analysis-action-icon">V</div>
            <h3>Vídeo</h3>
            <p>Use vídeo para uma futura análise multimodal mais completa.</p>
            <button type="button" class="btn-emodia-outline w-100" disabled>
              Em breve
            </button>
          </article>
        </div>
      </div>
    </section>

    <section class="analysis-section">
      <article class="analysis-warning-card surface-card">
        <div class="warning-icon">
          ⚠️
        </div>

        <div>
          <h2>Uso responsável</h2>

          <p>
            O Emodia é uma ferramenta de apoio ao autoconhecimento emocional.
            Ele não realiza diagnóstico médico, psicológico ou psiquiátrico.
            Caso emoções negativas persistam ou exista situação de crise,
            procure ajuda profissional. Em caso de crise, ligue CVV 188.
          </p>
        </div>
      </article>
    </section>
  </div>
</section>