NODE_ENV="development"
PORT=3000

DATABASE_URL="postgresql://usuario:senha@localhost:5432/emodia_db?schema=public"

SESSION_SECRET="gere_um_segredo_com_openssl_rand_hex_64"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="senha-de-aplicativo-do-email"
SMTP_FROM="Emodia <seu-email@gmail.com>"

APP_URL="http://localhost:3000"

# Ambiente Python
EMODIA_CONDA_ENV="emodia-ml"

# Transcrição
EMODIA_TRANSCRIPTION_MODE="local"
EMODIA_WHISPER_MODEL="small"
EMODIA_WHISPER_DEVICE="cpu"
EMODIA_TRANSCRIPTION_REMOTE_URL=""

# NLP — BERTimbau
EMODIA_NLP_ENABLED="true"
EMODIA_NLP_DEVICE="auto"
EMODIA_NLP_TIMEOUT_MS="120000"
EMODIA_NLP_MODEL_PATH="../ml/models/nlp/bertimbau"
EMODIA_NLP_SCRIPT_PATH="../ml/src/nlp/predict_text_emotion.py"
EMODIA_NLP_MIN_CONFIDENCE="0.50"
EMODIA_NLP_HIGH_CONFIDENCE="0.75"

# Visão computacional — ConvNeXtTiny RAF-DB V4
EMODIA_CV_ENABLED="true"
EMODIA_CV_DEVICE="cpu"
EMODIA_CV_TIMEOUT_MS="120000"
EMODIA_CV_FRAME_INTERVAL_SECONDS="0.5"
EMODIA_CV_MODEL_PATH="../ml/models/cv/convnexttiny_rafdb_v4/convnexttiny_rafdb_facecrop.onnx"
EMODIA_CV_LABELS_PATH="../ml/models/cv/convnexttiny_rafdb_v4/labels.json"
EMODIA_CV_FACIAL_SCRIPT_PATH="../ml/src/cv/predict_facial_emotion.py"
EMODIA_CV_VIDEO_SCRIPT_PATH="../ml/src/cv/predict_video_emotion.py"